{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dest",
    "target": "es2020",
    "lib": ["esnext", "dom"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src", "scripts", "src/artifacts/*", "target/**/*"]
}
